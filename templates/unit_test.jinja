unit_tests:
  - name: test_{{ plan.model_name }}
    model: {{ plan.model_name }}
    description: "Unit test for {{ plan.model_name }}"
    given:
{%- for table_name, rows in plan.unit_test.input_rows.items() %}
      - input: ref('{{ table_name }}')
        rows:
{%- for row in rows %}
          - { {% for col, val in row.items() %}{{ col }}: {% if val is string %}'{{ val }}'{% else %}{{ val }}{% endif %}{% if not loop.last %}, {% endif %}{% endfor %} }
{%- endfor %}
{%- endfor %}
    expect:
      rows:
{%- for row in plan.unit_test.expect_rows %}
        - { {% for col, val in row.items() %}{{ col }}: {% if val is string %}'{{ val }}'{% else %}{{ val }}{% endif %}{% if not loop.last %}, {% endif %}{% endfor %} }
{%- endfor %}
