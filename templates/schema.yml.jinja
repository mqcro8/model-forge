version: 2

models:
  - name: {{ plan.model_name }}
    description: "{{ plan.description }}"
    columns:
{%- for dim in plan.dimensions %}
      - name: {{ dim.name }}
        description: "{{ dim.description }}"
{%- set col_tests = [] %}
{%- if dim.name in plan.tests.unique_columns %}
{%-   set _ = col_tests.append("unique") %}
{%- endif %}
{%- if dim.name in plan.tests.not_null_columns %}
{%-   set _ = col_tests.append("not_null") %}
{%- endif %}
{%- if col_tests %}
        data_tests:
{%- for test in col_tests %}
          - {{ test }}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- for measure in plan.measures %}
      - name: {{ measure.name }}
        description: "{{ measure.description }}"
{%- set col_tests = [] %}
{%- if measure.name in plan.tests.unique_columns %}
{%-   set _ = col_tests.append("unique") %}
{%- endif %}
{%- if measure.name in plan.tests.not_null_columns %}
{%-   set _ = col_tests.append("not_null") %}
{%- endif %}
{%- if col_tests %}
        data_tests:
{%- for test in col_tests %}
          - {{ test }}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- if plan.tests.accepted_values or plan.tests.relationships %}
    data_tests:
{%- for av in plan.tests.accepted_values %}
      - accepted_values:
          column_name: {{ av.column }}
          values:
{%- for v in av.values %}
            - '{{ v }}'
{%- endfor %}
{%- endfor %}
{%- for rel in plan.tests.relationships %}
      - relationships:
          column_name: {{ rel.from_column }}
          to: ref('{{ rel.to_table }}')
          field: {{ rel.to_column }}
{%- endfor %}
{%- endif %}
