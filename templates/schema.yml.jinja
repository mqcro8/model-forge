version: 2

models:
  - name: {{ plan.model_name }}
    description: "{{ plan.description | replace('"', '\\"') }}"
    columns:
{%- for dim in plan.dimensions %}
      - name: {{ dim.name }}
        description: "{{ dim.description | replace('"', '\\"') }}"
{%- set col_tests = [] %}
{%- if dim.name in plan.tests.unique_columns %}
{%-   set _ = col_tests.append("unique") %}
{%- endif %}
{%- if dim.name in plan.tests.not_null_columns %}
{%-   set _ = col_tests.append("not_null") %}
{%- endif %}
{%- for av in plan.tests.accepted_values if av.column == dim.name %}
{%-   set _ = col_tests.append("accepted_values") %}
{%- endfor %}
{%- for rel in plan.tests.relationships if rel.from_column == dim.name %}
{%-   set _ = col_tests.append("relationships") %}
{%- endfor %}
{%- if col_tests %}
        data_tests:
{%- for test in col_tests %}
          - {{ test }}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- for measure in plan.measures %}
      - name: {{ measure.name }}
        description: "{{ measure.description | replace('"', '\\"') }}"
{%- set col_tests = [] %}
{%- if measure.name in plan.tests.unique_columns %}
{%-   set _ = col_tests.append("unique") %}
{%- endif %}
{%- if measure.name in plan.tests.not_null_columns %}
{%-   set _ = col_tests.append("not_null") %}
{%- endif %}
{%- for av in plan.tests.accepted_values if av.column == measure.name %}
{%-   set _ = col_tests.append("accepted_values") %}
{%- endfor %}
{%- for rel in plan.tests.relationships if rel.from_column == measure.name %}
{%-   set _ = col_tests.append("relationships") %}
{%- endfor %}
{%- if col_tests %}
        data_tests:
{%- for test in col_tests %}
          - {{ test }}
{%- endfor %}
{%- endif %}
{%- endfor %}
